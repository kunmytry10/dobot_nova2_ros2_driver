# Position can be set either by opening_mm or by position_permille.
# If opening_mm >= 0, it is converted using the configured stroke.
# If force_n >= 0, it is converted using the configured max force.
float64 opening_mm
int32 position_permille
int32 force_percent
float64 force_n
bool wait
float64 timeout_sec
---
bool success
string message
int32 init_state
int32 grip_state
int32 position_permille
float64 opening_mm
int32 force_percent
bool object_detected
bool object_dropped
